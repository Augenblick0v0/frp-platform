PLATFORM_DOMAIN=example.com
ADMIN_DOMAIN=admin.example.com
USER_DOMAIN=panel.example.com
API_DOMAIN=api.example.com
FRP_ENTRY_DOMAIN=frp.example.com
SERVER_ADDR=frp.example.com
FRP_TOKEN=replace-with-random-32-byte-frp-token

POSTGRES_DB=frp_platform
POSTGRES_USER=frp_platform
POSTGRES_PASSWORD=change-me-postgres
DATABASE_URL=postgres://frp_platform:change-me-postgres@postgres:5432/frp_platform?sslmode=disable
REDIS_PASSWORD=change-me-redis

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin
PURCHASE_URL=https://example.com/buy

SMTP_HOST=mail-server
SMTP_PORT=587
SMTP_USERNAME=no-reply@example.com
SMTP_PASSWORD=change-me-mail
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=FRP Platform
SMTP_TLS=false
SMTP_SKIP_VERIFY=false
LETSENCRYPT_EMAIL=admin@example.com

# Node machine address reachable from the control-plane API container.
NODE_AGENT_URL=http://NODE_SERVER_IP:8090
NODE_AGENT_TOKEN=change-me-node-agent-token

CERT_RENEW_BEFORE_DAYS=20
CERT_RENEW_INTERVAL=24h

PUBLIC_BASE_URL=https://panel.example.com
EPAY_API_BASE=https://pay.flwi.top
EPAY_SUBMIT_URL=https://pay.flwi.top/submit.php
EPAY_MAPI_URL=https://pay.flwi.top/mapi.php
EPAY_PID=
EPAY_KEY=
EPAY_APP_KEY=
EPAY_SITE_NAME=FRP Tunnel Platform

# Comma-separated browser origins allowed to call the API.
CORS_ALLOWED_ORIGINS=https://panel.example.com,https://admin.example.com
