PLATFORM_DOMAIN=example.com
FRP_ENTRY_DOMAIN=frp.example.com
FRP_BIND_PORT=7000
FRP_TOKEN=replace-with-random-32-byte-frp-token
FRP_VHOST_HTTP_PORT=8080
NODE_AGENT_TOKEN=replace-with-random-node-agent-token

CERTBOT_DRY_RUN=true
NGINX_TEST_CMD=docker exec frp-node-nginx nginx -t
NGINX_RELOAD_CMD=docker exec frp-node-nginx nginx -s reload
FRPS_STATUS_CMD=docker ps --filter name=frp-node-frps --filter status=running --format '{{.Names}} running'
FRPS_RESTART_CMD=docker restart frp-node-frps
FRPS_RELOAD_CMD=docker restart frp-node-frps

# Optional node self-binding to control plane. Create a node in admin panel, then paste bind token here.
CONTROL_PLANE_URL=https://api.example.com
NODE_BIND_TOKEN=
NODE_NAME=edge-node-1
NODE_PUBLIC_AGENT_URL=http://NODE_SERVER_IP:8090
NODE_PUBLIC_URL=http://NODE_SERVER_IP:8090
SERVER_ADDR=frp.example.com
TCP_PORT_START=20000
TCP_PORT_END=29999
UDP_PORT_START=30000
UDP_PORT_END=39999
