PLATFORM_DOMAIN=example.com
ADMIN_DOMAIN=admin.example.com
PANEL_DOMAIN=panel.example.com
API_DOMAIN=api.example.com
FRP_ENTRY_DOMAIN=frp.example.com
POSTGRES_DB=frp_platform
POSTGRES_USER=frp_platform
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://frp_platform:change-me@postgres:5432/frp_platform?sslmode=disable
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456
REDIS_PASSWORD=change-me
FRP_BIND_PORT=7000
FRP_TOKEN=change-me
FRP_VHOST_HTTP_PORT=8080
TCP_PORT_START=20000
TCP_PORT_END=29999
UDP_PORT_START=30000
UDP_PORT_END=39999
LETSENCRYPT_EMAIL=admin@example.com
MAIL_DOMAIN=example.com
MAIL_HOST=mail.example.com
SMTP_HOST=mail-server
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=change-me
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=FRP Tunnel Platform
SMTP_TLS=true
SMTP_SKIP_VERIFY=false
DMS_SSL_TYPE=manual
ENABLE_SPAMASSASSIN=0
ENABLE_CLAMAV=0
ENABLE_FAIL2BAN=0
ONE_DIR=1
NGINX_CONF_DIR=/app/runtime/nginx-conf.d
ACME_WEBROOT=/var/www/certbot
LETSENCRYPT_DIR=/etc/letsencrypt
FRP_VHOST_UPSTREAM=http://frps:8080
CERTBOT_BIN=certbot
CERTBOT_DRY_RUN=true
NGINX_TEST_CMD=
NGINX_RELOAD_CMD=
FRPS_CONFIG_PATH=/app/runtime/frps/frps.toml
FRPS_LOG_PATH=/app/runtime/logs/frps/frps.log
FRPS_STATUS_CMD=
FRPS_RESTART_CMD=
FRPS_RELOAD_CMD=
CERT_RENEW_BEFORE_DAYS=30
CERT_RENEW_INTERVAL=24h

# Optional: set these to make api-server manage a remote frps/nginx node through node-agent.
NODE_AGENT_URL=
NODE_AGENT_TOKEN=

PUBLIC_BASE_URL=https://panel.example.com
EPAY_API_BASE=https://pay.flwi.top
EPAY_SUBMIT_URL=https://pay.flwi.top/submit.php
EPAY_MAPI_URL=https://pay.flwi.top/mapi.php
EPAY_PID=
EPAY_KEY=
EPAY_APP_KEY=
EPAY_SITE_NAME=FRP Tunnel Platform
